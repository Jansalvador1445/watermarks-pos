# Environment variables for the backend
NODE_ENV=development
PORT=5000

MONGODB_URI=mongodb://localhost:27017/h2o-water-refilling?retryWrites=false

JWT_ACCESS_SECRET=h2o-access-secret-key-min-32-characters-long
JWT_REFRESH_SECRET=h2o-refresh-secret-key-min-32-characters-long

JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

CLIENT_URL=http://localhost:5173

COOKIE_SECURE=false
UPLOAD_DIR=uploads
BACKUP_DIR=backups
